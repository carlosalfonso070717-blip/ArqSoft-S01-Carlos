@model Catalogo.Models.Item

<div class="detail-page">
    <div class="detail-header">
        <a asp-action="Index" class="btn-back">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-arrow-left" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
            </svg>
            Volver al Catálogo
        </a>
    </div>

    <div class="detail-card">
        <div class="detail-layout">
            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
            {
                <div class="detail-image-container">
                    <img src="@Model.ImagenUrl" alt="@Model.Titulo" class="detail-image" />
                </div>
            }

            <div class="detail-content">
                <div class="detail-title-section">
                    <h1 class="detail-title">@Model.Titulo</h1>
                    <span class="detail-year">@Model.Ano</span>
                </div>

                <div class="detail-metadata">
                    <div class="metadata-item">
                        <div class="metadata-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-tag-fill" viewBox="0 0 16 16">
                                <path d="M2 1a1 1 0 0 0-1 1v4.586a1 1 0 0 0 .293.707l7 7a1 1 0 0 0 1.414 0l4.586-4.586a1 1 0 0 0 0-1.414l-7-7A1 1 0 0 0 6.586 1zm4 3.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                            </svg>
                        </div>
                        <div class="metadata-content">
                            <div class="metadata-label">Género</div>
                            <div class="metadata-value">@Model.Genero</div>
                        </div>
                    </div>

                    <div class="metadata-item">
                        <div class="metadata-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-tv-fill" viewBox="0 0 16 16">
                                <path d="M2.5 13.5A.5.5 0 0 1 3 13h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5M2 2h12s2 0 2 2v6s0 2-2 2H2s-2 0-2-2V4s0-2 2-2"/>
                            </svg>
                        </div>
                        <div class="metadata-content">
                            <div class="metadata-label">Consola</div>
                            <div class="metadata-value">@Model.Consola</div>
                        </div>
                    </div>

                    <div class="metadata-item">
                        <div class="metadata-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-calendar-event-fill" viewBox="0 0 16 16">
                                <path d="M4 .5a.5.5 0 0 0-1 0V1H2a2 2 0 0 0-2 2v1h16V3a2 2 0 0 0-2-2h-1V.5a.5.5 0 0 0-1 0V1H4zM16 14V5H0v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2m-3.5-7h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5"/>
                            </svg>
                        </div>
                        <div class="metadata-content">
                            <div class="metadata-label">Año de Lanzamiento</div>
                            <div class="metadata-value">@Model.Ano</div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Descripcion))
                {
                    <div class="detail-description">
                        <h3 class="description-title">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-info-circle" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                            </svg>
                            Descripción
                        </h3>
                        <p class="description-text">@Model.Descripcion</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>